# =============================================
# KickSight Environment Configuration
# =============================================
# Copy this to .env and fill in your values:
#   cp .env.example .env

# === Node.js Server (required) ===
PORT=3001
JWT_SECRET=change-this-to-a-random-secret-string

# PostgreSQL connection (required for auth + real data)
# Neon (free): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/kicksight?sslmode=require
# Local:       postgresql://postgres:postgres@localhost:5432/kicksight
DATABASE_URL=

# Optional: restrict CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === Python Backend (for ML features) ===
# Same DB, different driver prefixes:
DATABASE_URL_ASYNC=postgresql+asyncpg://user:pass@host/kicksight
DATABASE_URL_SYNC=postgresql+psycopg2://user:pass@host/kicksight

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# === API Keys (register for free) ===
# football-data.org — https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# the-odds-api.com — https://the-odds-api.com/#get-access
ODDS_API_KEY=

# OpenAI — https://platform.openai.com (paid, ~$0.01/report with gpt-4o-mini)
OPENAI_API_KEY=

# === Betting Engine Config ===
KELLY_FRACTION=0.25
MIN_EV_THRESHOLD=0.03
MAX_BET_FRACTION=0.05
BANKROLL=1000.0

LOG_LEVEL=INFO
ENVIRONMENT=development
