{
  "name": "kicksight",
  "version": "2.0.0",
  "private": true,
  "description": "KickSight - Football betting AI with predictions for the 2026 FIFA World Cup",
  "scripts": {
    "dev": "cd server && npm run dev",
    "start": "cd server && npm start",
    "install:server": "cd server && npm install",
    "install:mobile": "cd mobile && npm install",
    "install:all": "npm run install:server && npm run install:mobile",
    "install:python": "pip install -r requirements.txt",
    "build:mobile": "cd mobile && npx expo export --platform web",
    "db:init": "python scripts/ingest_real_data.py --seed",
    "db:ingest": "python scripts/ingest_real_data.py",
    "db:ingest:matches": "python scripts/ingest_real_data.py --matches",
    "db:ingest:odds": "python scripts/ingest_real_data.py --odds",
    "db:train": "python scripts/ingest_real_data.py --train",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": ["football", "betting", "ai", "world-cup-2026"],
  "license": "MIT"
}
