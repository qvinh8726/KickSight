# KickSight Server - Environment Variables
# Copy to .env and fill in values

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kicksight

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS (comma-separated, for production) ────────────
CORS_ORIGINS=https://qvinhdzaivcl.me,http://qvinhdzaivcl.me

# ─── External APIs (optional) ──────────────────────────
# FOOTBALL_API_KEY=your-api-sports-key
# OPENAI_API_KEY=your-openai-key
